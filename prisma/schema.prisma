generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Issue {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Automatically updates whenever the record is modified

  status Status  @default(OPEN)
  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

enum Status {
  OPEN
  IN_PROGRESS
  CLOSED
}

// =======================
// 📌 Model (Concept)
// =======================
// A model represents a TABLE in the database.
// It defines the structure of data (fields → columns).
// Each record in the table corresponds to one object of the model.
// Used to organize, store, and interact with data via Prisma Client.

// =======================
// 📌 Enum (Concept)
// =======================
// An enum defines a fixed set of allowed values for a field.
// It restricts data to predefined options (e.g., OPEN, CLOSED).
// Helps maintain data consistency and prevents invalid entries.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  accounts       Account[]
  sessions       Session[]
  assignedIssues Issue[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
